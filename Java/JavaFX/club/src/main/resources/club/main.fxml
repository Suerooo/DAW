<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="340.0" prefWidth="340.0" spacing="16.0"
      xmlns="http://javafx.com/javafx/13"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="club.controller.MainController">

    <children>
        <Label fx:id="mainLabelClub"
               text="CLUB"
               textAlignment="CENTER" />

        <Button fx:id="mainAddButton"
                onAction="#switchToAdd"
                prefWidth="180.0"
                text="ADD" />

        <Button fx:id="mainRemoveButton"
                onAction="#switchToRemove"
                prefWidth="180.0"
                text="REMOVE" />

        <Button fx:id="mainListButton"
                mnemonicParsing="false"
                onAction="#switchToList"
                prefWidth="180.0"
                text="LIST" />

        <Button fx:id="mainExitButton"
                mnemonicParsing="false"
                onAction="#exit"
                prefWidth="180.0"
                text="EXIT" />
    </children>

    <padding>
        <Insets top="28.0" right="28.0" bottom="28.0" left="28.0" />
    </padding>
</VBox>