<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="202.0" prefWidth="181.0" spacing="20.0" xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1" fx:controller="club.controller.AddController">
    <children>
      <BorderPane prefHeight="22.0" prefWidth="124.0">
         <left>
              <Button fx:id="addButtonBack" onAction="#switchToMenu" prefHeight="25.0" prefWidth="43.0" text="Back" BorderPane.alignment="CENTER" />
         </left>
         <center>
              <Label fx:id="addLabel" prefHeight="17.0" prefWidth="55.0" text="ADD" BorderPane.alignment="CENTER" />
         </center>
      </BorderPane>
      <Label fx:id="addErrorLabel" />
      <TextField fx:id="addTituloField" promptText="Titulo" />
      <TextField fx:id="addAnioField" promptText="Año" />
      <TextField fx:id="addDuracionField" promptText="Duracion" />
      <Button fx:id="addButtonEnviar" mnemonicParsing="false" onAction="#saveClub" text="Enviar" />
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
