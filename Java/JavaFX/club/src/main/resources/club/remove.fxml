<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="280.0" prefWidth="340.0" spacing="18.0"
      xmlns="http://javafx.com/javafx/13"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="club.controller.RemoveController">

    <children>
        <BorderPane prefWidth="280.0">
            <left>
                <Button fx:id="removeButtonBack"
                        onAction="#switchToMenu"
                        text="Back"
                        BorderPane.alignment="CENTER" />
            </left>
            <center>
                <Label fx:id="removeLabel"
                       text="REMOVE"
                       BorderPane.alignment="CENTER" />
            </center>
        </BorderPane>

        <TextField fx:id="removeTituloField"
                   maxWidth="220.0"
                   promptText="Título" />

        <Button fx:id="removeButton"
                mnemonicParsing="false"
                onAction="#removeClub"
                prefWidth="180.0"
                text="Eliminar" />
    </children>

    <padding>
        <Insets top="28.0" right="28.0" bottom="28.0" left="28.0" />
    </padding>
</VBox>